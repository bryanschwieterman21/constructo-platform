{
  "name": "constructo-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate --filter=@constructo/database",
    "db:push": "turbo run db:push --filter=@constructo/database",
    "db:migrate": "turbo run db:migrate --filter=@constructo/database",
    "db:studio": "turbo run db:studio --filter=@constructo/database"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "packageManager": "npm@10.0.0"
}
